    "import sqlite3\n",
    "\n",
    "conn = sqlite3.connect(\"C:/Users/Terri/Documents/github_projects/ILRHA_Points_2025/db/ilrha2025v0428.db\")\n",
    "cursor = conn.cursor()\n",
    "\n",
    "query = '''\n",
    "SELECT \n",
    "    r.show_id, s.show_name, s.date, h.horse_name, p.name AS exhibitor_name, r.class_name as class_name\n",
    "FROM results r\n",
    "JOIN horses h ON r.horse_arha_no = h.arha_no\n",
    "JOIN people p ON r.exhibitor_arha_no = p.arha_no\n",
    "JOIN shows s ON r.show_id = s.show_id\n",
    "WHERE exhibitor_name LIKE '%bloom%'\n",
    "ORDER BY s.date;\n",
    "'''\n",
    "\n",
    "cursor.execute(query)\n",
    "rows = cursor.fetchall()\n",
    "\n",
    "for row in rows:\n",
    "    print(row)\n",
    "\n",
    "conn.close()\n"
   ]
